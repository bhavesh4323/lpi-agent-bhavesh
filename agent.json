{\n  "@context": "https://www.w3.org/2019/wot/td/v1",\n  "@type": "Agent",\n  "id": "https://github.com/bhavesh4323/lpi-agent-bhavesh",\n  "name": "LPI Explainable Agent",\n  "description": "An AI agent that queries the Life Programmable Interface to provide explainable answers by combining knowledge from multiple tools.",\n  "version": "1.0.0",\n  "author": {\n    "name": "Bhavesh Pal",\n    "url": "https://github.com/bhavesh4323"\n  },\n  "capabilities": [\n    {\n      "id": "query_knowledge",\n      "name": "Knowledge Base Query",\n      "description": "Search the LPI knowledge base for information on digital twins, SMILE methodology, and implementation strategies.",\n      "type": "query",\n      "parameters": {\n        "query": {\n          "type": "string",\n          "required": true,\n          "description": "The search query to execute against the knowledge base"\n        }\n      },\n      "outputFormat": "application/json"\n    },\n    {\n      "id": "get_insights",\n      "name": "Scenario Insights",\n      "description": "Get scenario-specific recommendations and implementation insights from the LPI.",\n      "type": "insight",\n      "parameters": {\n        "scenario": {\n          "type": "string",\n          "required": true,\n          "description": "The scenario or use case to get insights for"\n        },\n        "tier": {\n          "type": "string",\n          "enum": ["free", "pro", "enterprise"],\n          "default": "free",\n          "description": "The tier level for insights"\n        }\n      },\n      "outputFormat": "application/json"\n    }\n  ],\n  "features": [\n    "Explainable AI - Shows which tools provided which information",\n    "Multi-tool synthesis - Combines results from 2+ tools",\n    "Error handling - Graceful failure with helpful messages",\n    "Configurable - Works with different server URLs",\n    "Transparent - Full source attribution for all answers"\n  ],\n  "inputFormat": "text/plain",\n  "outputFormat": "text/plain",\n  "requirements": [\n    "Python 3.8+",\n    "requests library",\n    "Running LPI sandbox server"\n  ],\n  "usageExample": {\n    "input": "Explain digital twins in simple terms",\n    "output": "Synthesized answer combining knowledge base and scenario insights"\n  },\n  "repository": "https://github.com/bhavesh4323/lpi-agent-bhavesh",\n  "license": "MIT",\n  "tags": [\n    "explainable-ai",\n    "multi-tool",\n    "digital-twins",\n    "SMILE",\n    "LPI"\n  ]\n}